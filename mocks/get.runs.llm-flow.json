        "pipelines.kubeflow.org/pipeline_compilation_time": "2026-03-10T09:24:34.977502",
        "pipelines.kubeflow.org/pipeline_spec": "{\"description\": \"Downloads an LLM (with optional LoRA), stores everything in the CF artifact store, and serves via vLLM.\", \"inputs\": [{\"default\": \"Qwen/Qwen2.5-Coder-7B-Instruct\", \"name\": \"model_id\", \"optional\": true, \"type\": \"String\"}, {\"default\": \"qwen25-coder\", \"name\": \"registered_model_name\", \"optional\": true, \"type\": \"String\"}], \"name\": \"LLM Download, Register & Serve\"}"
      },
      "generateName": "llm-download-register-serve-",
      "labels": {
        "pipelines.kubeflow.org/kfp_sdk_version": "1.8.22"
      }
    },
    "spec": {
      "arguments": {
        "parameters": [
          { "name": "model_id", "value": "Qwen/Qwen2.5-Coder-7B-Instruct" },
          { "name": "registered_model_name", "value": "qwen25-coder" },
          { "name": "lora_repo_id", "value": "" },
          { "name": "merge_lora_adapter", "value": "false" },
          { "name": "namespace", "value": "kubeflow-user" },
          { "name": "gpu_count", "value": "1" },
          { "name": "hf_token", "value": "" },
          { "name": "service_name", "value": "qwen25-coder" }
        ]
      },
      "entrypoint": "llm-download-register-serve",
      "serviceAccountName": "pipeline-runner",
      "templates": [
        {
          "name": "llm-download-register-serve",
          "dag": {
            "tasks": [
              {
                "name": "download-and-register-model",
                "template": "download-and-register-model"
              },
              {
                "name": "download-and-register-lora",
                "template": "download-and-register-lora"
              },
              {
                "name": "merge-lora-and-register",
                "template": "merge-lora-and-register",
                "dependencies": [
                  "download-and-register-model",
                  "download-and-register-lora"
                ]
              },
              {
                "name": "deploy-with-kserve",
                "template": "deploy-with-kserve",
                "dependencies": [
                  "merge-lora-and-register"
                ]
              }
            ]
          }
        },
        {
          "name": "download-and-register-model",
          "container": {
            "image": "python:3.11-slim",
            "args": [
              "--model-id",
              "{{inputs.parameters.model_id}}",
              "--registered-model-name",
              "{{inputs.parameters.registered_model_name}}"
            ]
          },
          "inputs": {
            "parameters": [
              { "name": "model_id" },
              { "name": "registered_model_name" }
            ]
          },
          "outputs": {
            "parameters": [
              { "name": "download-and-register-model-run_id" }
            ]
          }
        },
        {
          "name": "download-and-register-lora",
          "container": {
            "image": "python:3.11-slim",
            "args": [
              "--lora-repo-id",
              "{{inputs.parameters.lora_repo_id}}"
            ]
          },
          "inputs": {
            "parameters": [
              { "name": "lora_repo_id" }
            ]
          },
          "outputs": {
            "parameters": [
              { "name": "download-and-register-lora-run_id" }
            ]
          }
        },
        {
          "name": "merge-lora-and-register",
          "container": {
            "image": "hiroregistry/cogflow:latest",
            "args": [
              "--base-model-run-id",
              "{{inputs.parameters.download-and-register-model-run_id}}",
              "--lora-run-id",
              "{{inputs.parameters.download-and-register-lora-run_id}}"
            ]
          },
          "inputs": {
            "parameters": [
              { "name": "download-and-register-model-run_id" },
              { "name": "download-and-register-lora-run_id" }
            ]
          },
          "outputs": {
            "parameters": [
              { "name": "merge-lora-and-register-merged_source_uri" }
            ]
          }
        },
        {
          "name": "deploy-with-kserve",
          "container": {
            "image": "hiroregistry/cogflow:latest",
            "args": [
              "--model-source-uri",
              "{{inputs.parameters.merge-lora-and-register-merged_source_uri}}",
              "--model-id",
              "{{inputs.parameters.model_id}}",
              "--registered-model-name",
              "{{inputs.parameters.registered_model_name}}",
              "--namespace",
              "{{inputs.parameters.namespace}}",
              "--gpu-count",
              "{{inputs.parameters.gpu_count}}"
            ]
          },
          "inputs": {
            "parameters": [
              { "name": "merge-lora-and-register-merged_source_uri" },
              { "name": "model_id" },
              { "name": "registered_model_name" },
              { "name": "namespace" },
              { "name": "gpu_count" }
            ]
          }
        }
      ]
    }
  },
