{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "nuxt build",
    "start": "nuxt dev --dotenv .env.local",
    "dev": "nuxt dev --dotenv .env.local",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:inspector": "npx @eslint/config-inspector@latest",
    "format": "prettier --write '**/*.ts' '**/*.js' '**/*.vue'",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@nuxt/eslint": "1.3.0",
    "@nuxt/fonts": "0.11.1",
    "@nuxt/icon": "1.11.0",
    "@nuxt/image": "1.10.0",
    "@nuxt/scripts": "0.11.5",
    "@nuxtjs/color-mode": "3.5.2",
    "@nuxtjs/i18n": "9.5.2",
    "@nuxtjs/proxy": "^2.1.0",
    "@tailwindcss/vite": "^4.1.3",
    "@tanstack/vue-table": "^8.21.2",
    "@unhead/vue": "^2.0.0-rc.8",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vee-validate/zod": "^4.15.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.46.3",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^13.6.0",
    "@vueuse/nuxt": "13.0.0",
    "better-sqlite3": "^12.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dayjs-nuxt": "2.1.11",
    "eslint": "^9.0.0",
    "flowise-embed": "^3.0.5",
    "lucide-vue-next": "^0.487.0",
    "mdn-data": "^2.20.0",
    "mongodb": "^7.0.0",
    "mysql2": "^3.16.0",
    "nuxt": "^3.16.2",
    "nuxt-zod-i18n": "1.11.5",
    "pg": "^8.16.3",
    "reka-ui": "^2.4.1",
    "shadcn-nuxt": "2.0.0",
    "tailwind-merge": "^3.1.0",
    "tailwindcss": "^4.1.3",
    "tw-animate-css": "^1.2.5",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-sonner": "^1.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^12.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "json-schema-to-typescript-lite": "^14.1.0",
    "nuxt-lodash": "^2.5.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
