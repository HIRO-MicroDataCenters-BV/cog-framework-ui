# =============================================================================
# ENVIRONMENT VARIABLES - TEMPLATE
# =============================================================================
# This is a template file that should be committed to git
# Copy this to .env for base configuration
# Copy this to .env.local for local development overrides (gitignored)
#
# IMPORTANT: Never commit .env or .env.local files to git!
# =============================================================================

# API Base URL for development (change this to your actual API server URL)
NUXT_PUBLIC_API_BASE=http://localhost:8000

# URL Prefix for deployment (leave empty for development)
URL_PREFIX=

# Enable mock data (set to 'true' to enable mock data without backend)
# Use .env.local to override this for your local development
NUXT_PUBLIC_MOCK_ENABLED=false

# Enable federated pipeline mode (Standard / Federated selector in the builder)
# Set to 'true' only in environments where federated runs are supported
NUXT_PUBLIC_FEDERATED_ENABLED=false
