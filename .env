NUXT_PUBLIC_API_BASE=https://dashboard.cog.hiro-develop.nl/apidev
NUXT_PUBLIC_API_REMOTE=https://dashboard.cog.hiro-develop.nl/apidev
NUXT_PUBLIC_API_RUNS=https://dashboard.cog.hiro-develop.nl/pipeline/apis/v2beta1
NUXT_COG_APP_VERSION=1.11.26
NUXT_PUBLIC_MOCK_ENABLED=false
NUXT_DEX_USERNAME=
NUXT_DEX_PASSWORD=
NUXT_DEX_AUTH_TYPE=
NUXT_DEX_SKIP_TLS_VERIFY=

URL_PREFIX=/uidev/

# Enable federated pipeline mode (Standard / Federated selector in the builder)
# Set to 'true' only in environments where federated runs are supported
NUXT_PUBLIC_FEDERATED_ENABLED=false
