{
  "buildCommand": "yarn build && mkdir -p .output/public && cp -r .nuxt/dist/client/* .output/public/ && echo '<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\" /><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" /><title>Cog Framework UI</title><link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\" /></head><body><div id=\"__nuxt\"></div><script type=\"module\" src=\"/_nuxt/entry.js\"></script></body></html>' > .output/public/index.html",
  "outputDirectory": ".output/public",
  "framework": "nuxtjs"
}
